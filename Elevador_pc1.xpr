library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity elevador is
    Port (
        clk  : in  STD_LOGIC; -- toda vez que bater faço alguma coisa
        rst  : in  STD_LOGIC; -- reseta 
        B0   : in  STD_LOGIC;-- botoess
        B1   : in  STD_LOGIC;
        B2   : in  STD_LOGIC;
        B3   : in  STD_LOGIC;
        Q    : out STD_LOGIC_VECTOR (1 downto 0); -- onde o elevador ta 
        DOOR : out STD_LOGIC -- porta abre fecha
    );
end elevador;

architecture Behavioral of elevador is

    signal estado : unsigned(1 downto 0) := "00"; -- onde (unsigned pq o pode somar ou subtrair)
    signal pedidos : STD_LOGIC_VECTOR(3 downto 0) := "0000"; -- quem / qual andar chamou o elevador 
    signal UP, DOWN : STD_LOGIC; -- decisoes
    signal door_counter : integer := 0;  -- quanto tempo a porta fica aberta

begin
 
    -- portas logicas (UP/DOWN)
    

    UP <= (not estado(1) and not estado(0) and (pedidos(1) or pedidos(2) or pedidos(3))) or
          (not estado(1) and estado(0) and (pedidos(2) or pedidos(3))) or
          (estado(1) and not estado(0) and pedidos(3));

    DOWN <= (estado(1) and estado(0) and (pedidos(0) or pedidos(1) or pedidos(2))) or
            (estado(1) and not estado(0) and (pedidos(0) or pedidos(1))) or
            (not estado(1) and estado(0) and pedidos(0));


    process(clk, rst)
    begin
        if rst = '1' then
            estado <= "00";
            pedidos <= "0000";
            door_counter <= 0;

        elsif rising_edge(clk) then
           
           -- vai guardar os pedidos
            pedidos(0) <= pedidos(0) or B0;
            pedidos(1) <= pedidos(1) or B1;
            pedidos(2) <= pedidos(2) or B2;
            pedidos(3) <= pedidos(3) or B3;

            -- abrir a porta
            if (estado = "00" and pedidos(0)='1') or
               (estado = "01" and pedidos(1)='1') or    -- se alguma dessas for verdade a porta vai abrirr
               (estado = "10" and pedidos(2)='1') or
               (estado = "11" and pedidos(3)='1') then

                door_counter <= 5; -- tempo da porta aberta a cada clock diminui 1 s ate chegar em 0 e fechar 
                pedidos(to_integer(estado)) <= '0';

            elsif door_counter > 0 then
                door_counter <= door_counter - 1;

            else

                -- MUX if vai ser = ESCOLHA se desce se sobe ou se fica parado

                if UP = '1' then
                    if estado < "11" then
                        estado <= estado + 1;
                    end if;

                elsif DOWN = '1' then
                    if estado > "00" then
                        estado <= estado - 1;
                    end if;

                end if;

            end if;
        end if;
    end process;

    -- Saida
    Q <= std_logic_vector(estado);
    DOOR <= '1' when door_counter > 0 else '0'; -- andar que o elevador ta e se a porta ta aberta oou fechada

end Behavioral;
